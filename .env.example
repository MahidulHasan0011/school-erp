# --- Database (Supabase PostgreSQL) ---
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# --- App ---
PORT=3000
NODE_ENV=development

# --- JWT ---
JWT_SECRET=change-me-in-env
JWT_REFRESH_SECRET=change-me-refresh
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Redis (auth session / token revocation) ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
# cloud Redis (Upstash/etc.) হলে true
REDIS_TLS=false

# --- RabbitMQ (ranking background jobs) ---
RABBITMQ_URL=amqp://guest:guest@127.0.0.1:5672
RABBITMQ_PREFETCH=5
RABBITMQ_MAX_DELAY_MS=60000

# --- S3 / MinIO (file uploads, presigned URL) ---
# লোকাল MinIO (docker-compose) — endpoint দিলে path-style ব্যবহার হয়।
# AWS S3 হলে S3_ENDPOINT ফাঁকা রাখুন এবং আসল region/bucket দিন।
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=school-erp
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_PUBLIC_URL=http://localhost:9000/school-erp